# Dependencies
node_modules/

# Build output
dist/
build/

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Logs
logs/
*.log
npm-debug.log*

# Environment files
.env
.env.local
.env.*.local

# Test files
tests/
coverage/
.nyc_output/

# Documentation (optional - include if needed)
docs/

# Git
.git/
.gitignore

# OpenClaw workspace (exclude from image, mount as volume instead)
~/.openclaw/workspace/
~/.openclaw/sessions/

# Development files
*.test.ts
*.spec.ts
jest.config.js
tsconfig.json

# Scripts (optional - include if needed for runtime)
scripts/*.sh

# Docker files themselves (already in context)
Dockerfile*
docker-compose*.yml
.dockerignore

# Additional exclusions for smaller image
**/.gitkeep
**/README.md
**/CHANGELOG.md
**/CONTRIBUTING.md
**/CODE_OF_CONDUCT.md
**/SECURITY.md

# Build artifacts
*.tsbuildinfo
*.tsbuildinfo

# Temporary files
tmp/
temp/
.cache/

# Coverage reports
coverage/
.nyc_output/

# TypeScript declaration maps (optional)
*.d.ts.map

# Pnpm specific
.pnpm-store/
